#!/bin/sh
# ringo-tmux — pick profiles via fzf and open each in a tmux pane
#
# Usage: ringo-tmux [query]
# Requires: ringo, tmux, fzf, jq

set -e

# Dependency checks
for cmd in tmux fzf jq ringo; do
    command -v "$cmd" > /dev/null 2>&1 || { echo "ringo-tmux: '$cmd' not found" >&2; exit 1; }
done

# Profile selection via fzf multi-select (show name + aor, return name only)
selections=$(ringo list --json | jq -r '.[] | "\(.name) · \(.aor)"' | fzf --multi \
    --delimiter=' · ' \
    --prompt="ringo profiles > " \
    --header="Tab=toggle  Ctrl-A=all  Ctrl-D=none  Enter=confirm" \
    --bind 'ctrl-a:select-all,ctrl-d:deselect-all' \
    --query="${1:-}")
[ -z "$selections" ] && exit 0

# Extract profile names (first column)
profiles=$(printf '%s\n' "$selections" | cut -d'·' -f1 | sed 's/ *$//')

SESSION="ringo"
first=1

echo "$profiles" | while IFS= read -r profile; do
    if [ "$first" = "1" ]; then
        # Create new session (detached) with first profile, or new window if session exists
        if tmux has-session -t "$SESSION" 2>/dev/null; then
            tmux new-window -t "$SESSION" -n "$profile" "ringo start '$profile'"
        else
            tmux new-session -d -s "$SESSION" -n "$profile" "ringo start '$profile'"
        fi
        first=0
    else
        tmux split-window -t "$SESSION" "ringo start '$profile'"
    fi
done

# Even layout
tmux select-layout -t "$SESSION" tiled

# Attach or switch
if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION"
else
    tmux attach-session -t "$SESSION"
fi
